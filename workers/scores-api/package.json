{
  "name": "vernan-scores-api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute vernan-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute vernan-db --local --file=./schema.sql",
    "seed": "wrangler kv key put --binding=SCORES scores --path=../../data/scores.json --remote --preview false",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.0"
  }
}
