{
  "name": "vernan-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Portable TypeScript/Canvas port of Vernan — embeddable on any static host",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "sync-assets": "node scripts/pack-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
